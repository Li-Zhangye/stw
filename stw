#!/usr/bin/env bash
# ==============================================================
#  stw - 短信转网页 命令行管理工具（类似宝塔 bt 命令）
#  用法: stw [选项编号]  或  stw 直接进入交互菜单
# ==============================================================
set -e

# paths
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
STW_DIR="${STW_DIR:-$SCRIPT_DIR}"
SERVER_PY="$STW_DIR/server/server.py"
DATA_DIR="${DATA_DIR:-$STW_DIR/tmp/data}"
MOD_DIR="${MOD_DIR:-$STW_DIR/mod}"
MANAGERS="$DATA_DIR/managers.json"
CONFIG_FILE="$DATA_DIR/config.json"
PID_FILE="$STW_DIR/tmp/server.pid"
DAEMON_PID_FILE="$DATA_DIR/daemon.pid"
LOG_DIR="$STW_DIR/tmp"
SERVER_LOG="$LOG_DIR/server.log"
DAEMON_LOG="$LOG_DIR/daemon.log"
OS_RELEASE="/etc/os-release"

if [ -t 1 ]; then
    RED=$(printf '\033[91m'); GREEN=$(printf '\033[92m'); YELLOW=$(printf '\033[93m')
    CYAN=$(printf '\033[96m'); BOLD=$(printf '\033[1m'); RESET=$(printf '\033[0m')
else
    RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; RESET=''
fi
ok()   { echo "  [OK] $1"; }
fail() { printf "  %s[FAIL]%s %s\n" "$RED" "$RESET" "$1"; }
warn() { echo "  [!] $1"; }
info() { echo "  [i] $1"; }

# dependencies
PYTHON=$(command -v python3 || command -v python || true)
[ -z "$PYTHON" ] && { fail "Python 未安装"; exit 1; }

# -- 工具函数 --
_read_json() {
    local f="$1" key="$2"
    [ ! -f "$f" ] && { echo ""; return; }
    local tmpf=$(mktemp /tmp/stw_read.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_read.$$"
    printf '%s' "$key" > "$tmpf"
    $PYTHON -c "import json; k=open('$tmpf','r').read(); d=json.load(open('$f')); print(d.get(k,''))" 2>/dev/null || { rm -f "$tmpf"; echo ""; return; }
    rm -f "$tmpf"
}

_write_json() {
    local f="$1" key="$2" val="$3"
    mkdir -p "$(dirname "$f")"
    local tmpf=$(mktemp /tmp/stw_write.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_write.$$"
    printf '%s' "$val" > "$tmpf"
    $PYTHON -c "
import json, sys
f=sys.argv[1]; k=sys.argv[2]
val = open(sys.argv[3], 'r').read()
try:
    d=json.load(open(f))
except:
    d={}
try:
    d[k]=json.loads(val)
except:
    d[k]=val
json.dump(d, open(f,'w'), indent=2, ensure_ascii=False)
" "$f" "$key" "$tmpf" 2>/dev/null || { warn "写入 $f 失败"; rm -f "$tmpf"; return 1; }
    rm -f "$tmpf"
}

_get_managers() {
    [ ! -f "$MANAGERS" ] && return
    local tmpf=$(mktemp /tmp/stw_mgr.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_mgr.$$"
    printf '%s' "$MANAGERS" > "$tmpf"
    $PYTHON -c "
import json
p = open('$tmpf','r').read()
d=json.load(open(p))
for m in d:
    print(m.get('username',''), m.get('password_hash','')[:16]+'...', m.get('level',1), m.get('created_at',''))
" 2>/dev/null
    rm -f "$tmpf"
}

_random_password() {
    tr -dc 'A-Za-z0-9!@#$%^&*' < /dev/urandom 2>/dev/null | head -c16 || printf 'sms2web%s' "$(date +%s)"
}

_yes_no() {
    local msg="$1" def="${2:-yes}"
    local prompt=""
    [ "$def" = "yes" ] && prompt="[Y/n]" || prompt="[y/N]"
    read -p "  [?] $msg $prompt: " ans
    ans=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]')
    [ -z "$ans" ] && ans="$def"
    [ "$ans" = "yes" ] || [ "$ans" = "y" ] || [ "$ans" = "true" ] || [ "$ans" = "1" ]
}

_ssl_is_active() {
    local proto
    proto=$(_server_info_val protocol 2>/dev/null)
    if [ -n "$proto" ]; then
        echo "$proto"
        return
    fi
    local enabled
    enabled=$(_read_json "$CONFIG_FILE" "ssl_enabled")
    if [ "$enabled" = "true" ] && [ -f "$DATA_DIR/ssl/server.crt" ] && [ -f "$DATA_DIR/ssl/server.key" ]; then
        echo "https"
    else
        echo "http"
    fi
}

# -- 缓存清理 --
_clean_panel_cache() {
    echo ""
    info "清理面板缓存..."
    # 日志文件
    for f in "$SERVER_LOG" "$DAEMON_LOG"; do
        if [ -f "$f" ]; then
            local sz=$(stat -c%s "$f" 2>/dev/null || echo 0)
            : > "$f"
            local sz_hr=""
            [ "$sz" -ge 1048576 ] && sz_hr="$((sz/1048576))MB" || sz_hr="$((sz/1024))KB"
            ok "已清空: $(basename $f) ($sz_hr)"
        fi
    done
    # tmp 目录下 .pyc 缓存
    local pyc_count=0
    while IFS= read -r f; do
        rm -f "$f" 2>/dev/null && pyc_count=$((pyc_count+1))
    done < <(find "$STW_DIR" -name "*.pyc" -type f 2>/dev/null)
    [ "$pyc_count" -gt 0 ] && ok "清理 $pyc_count 个 .pyc 缓存文件"
    # __pycache__ 目录
    local pc_count=0
    while IFS= read -r d; do
        rm -rf "$d" 2>/dev/null && pc_count=$((pc_count+1))
    done < <(find "$STW_DIR" -type d -name "__pycache__" 2>/dev/null)
    [ "$pc_count" -gt 0 ] && ok "清理 $pc_count 个 __pycache__ 目录"
    # data 目录下 session 文件
    local sess_count=0
    while IFS= read -r f; do
        if [ -f "$f" ]; then
            rm -f "$f" 2>/dev/null && sess_count=$((sess_count+1))
        fi
    done < <(find "$DATA_DIR" -name "session_*" -type f 2>/dev/null)
    [ "$sess_count" -gt 0 ] && ok "清理 $sess_count 个会话文件"
    ok "面板缓存清理完成"
}

_get_port() {
    local label="$1" port=""
    _load_server_info
    [ "$label" = "用户" ] && port=$(_server_info_val user_port)
    [ "$label" = "管理" ] && port=$(_server_info_val admin_port)
    [ -z "$port" ] && [ "$label" = "用户" ] && port=$(_read_json "$CONFIG_FILE" "force_user_port")
    [ -z "$port" ] && [ "$label" = "管理" ] && port=$(_read_json "$CONFIG_FILE" "force_admin_port")
    [ -z "$port" ] && port="19672"
    echo "$port"
}

_clean_system_cache() {
    echo ""
    warn "系统缓存清理 (仅清理安全目录，绝不删除系统文件)"
    echo ""
    local freed=0
    # 检测包管理器缓存
    if command -v apt-get >/dev/null 2>&1; then
        local sz=$(du -sb /var/cache/apt 2>/dev/null | cut -f1)
        apt-get clean 2>/dev/null && ok "APT 缓存已清理" || warn "APT 清理失败(需要root?)"
        freed=$((freed + ${sz:-0}))
    fi
    if command -v dnf >/dev/null 2>&1; then
        local sz=$(du -sb /var/cache/dnf 2>/dev/null | cut -f1)
        dnf clean all 2>/dev/null && ok "DNF 缓存已清理" || warn "DNF 清理失败"
        freed=$((freed + ${sz:-0}))
    fi
    if command -v yum >/dev/null 2>&1; then
        local sz=$(du -sb /var/cache/yum 2>/dev/null | cut -f1)
        yum clean all 2>/dev/null && ok "YUM 缓存已清理" || warn "YUM 清理失败"
        freed=$((freed + ${sz:-0}))
    fi
    if command -v pacman >/dev/null 2>&1; then
        pacman -Scc --noconfirm 2>/dev/null && ok "Pacman 缓存已清理" || warn "Pacman 清理失败"
    fi
    # 清理 /tmp 下应用临时文件（不删 /tmp 本身）
    local tmp_count=0
    while IFS= read -r f; do
        rm -rf "$f" 2>/dev/null && tmp_count=$((tmp_count+1))
    done < <(find /tmp -maxdepth 1 \( -name "tmp*" -o -name "*.tmp" -o -name "pip-*" -o -name "python*" \) 2>/dev/null | head -100)
    [ "$tmp_count" -gt 0 ] && ok "清理 $tmp_count 个临时文件"
    # 清理 journal 日志（仅保留最近 100M）
    if command -v journalctl >/dev/null 2>&1; then
        journalctl --vacuum-size=100M 2>/dev/null && ok "Systemd 日志已压缩" || true
    fi
    echo ""
    ok "系统缓存清理完成"
    warn "安全提示: 仅清理了包管理器和 /tmp 下的临时文件，未删除任何系统文件"
}

# -- 系统检测 --
_detect_os() {
    DISTRO_ID=""; DISTRO_VERSION=""; DISTRO_PRETTY=""
    if [ -f "$OS_RELEASE" ]; then
        . "$OS_RELEASE"
        DISTRO_ID="$ID"; DISTRO_VERSION="$VERSION_ID"; DISTRO_PRETTY="$PRETTY_NAME"
    fi
    echo "  系统: ${DISTRO_PRETTY:-$(uname -s)} $(uname -m)"
    echo "  Python: $($PYTHON --version 2>&1)"
    echo "  安装目录: $STW_DIR"
}

# -- 服务控制 --
_start() {
    if [ -f "$PID_FILE" ]; then
        local pid=$(cat "$PID_FILE" 2>/dev/null)
        if kill -0 "$pid" 2>/dev/null; then
            warn "面板已在运行 (PID $pid)"
            return
        fi
    fi
    mkdir -p "$DATA_DIR" "$LOG_DIR"
    cd "$STW_DIR"
    DATA_DIR="$DATA_DIR" MOD_DIR="$MOD_DIR" nohup $PYTHON "$SERVER_PY" > "$SERVER_LOG" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    sleep 3
    if kill -0 "$pid" 2>/dev/null; then
        ok "面板已启动 (PID $pid)"
        sleep 1
        local dpid=""
        [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
        if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
            ok "守护进程已启动 (PID $dpid)"
        else
            warn "守护进程可能未启动，检查日志: $DAEMON_LOG"
        fi
    else
        fail "面板启动失败，查看日志: $SERVER_LOG"
    fi
}

_start_daemon_only() {
    local dpid=""
    [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
        warn "守护进程已在运行 (PID $dpid)"
        return
    fi
    mkdir -p "$DATA_DIR" "$LOG_DIR"
    cd "$STW_DIR"
    DATA_DIR="$DATA_DIR" nohup $PYTHON "$STW_DIR/server/daemon.py" > "$DAEMON_LOG" 2>&1 &
    local dpid=$!
    sleep 2
    if kill -0 "$dpid" 2>/dev/null; then
        ok "守护进程已启动 (PID $dpid)"
    else
        fail "守护进程启动失败，查看日志: $DAEMON_LOG"
    fi
}

_daemon_status() {
    _load_server_info
    local d_port=$(_server_info_val daemon_port)
    local dpid=""
    [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
        local duptime=$(ps -o etime= -p "$dpid" 2>/dev/null | xargs)
        echo ""
        echo "  [运行中] 守护进程 (Daemon)"
        echo "  PID: $dpid"
        echo "  运行时长: ${duptime:-未知}"
        [ -n "$d_port" ] && echo "  通信端口: $d_port"
        echo ""
        tail -3 "$DAEMON_LOG" 2>/dev/null | sed 's/^/  /'
    else
        echo "  [未运行] 守护进程 (Daemon)"
    fi
}

_stop_daemon_only() {
    local dpid=""
    [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
        kill "$dpid" 2>/dev/null && ok "守护进程已停止 (PID $dpid)" || true
        rm -f "$DAEMON_PID_FILE"
    fi
    dpid=$(pgrep -f "daemon.py" 2>/dev/null | head -1)
    [ -n "$dpid" ] && kill "$dpid" 2>/dev/null && ok "守护进程已强制停止" || true
}

_stop() {
    local pid
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE" 2>/dev/null)
        kill "$pid" 2>/dev/null && ok "面板已停止 (PID $pid)" || warn "面板进程 $pid 不存在"
        rm -f "$PID_FILE"
    else
        pid=$(pgrep -f "server.py" 2>/dev/null | head -1)
        [ -n "$pid" ] && { kill "$pid" 2>/dev/null && ok "面板已停止"; } || warn "未找到运行中的面板"
    fi
    _stop_daemon_only
}

_status() {
    _load_server_info
    local u_port=$(_server_info_val user_port)
    local a_port=$(_server_info_val admin_port)
    local d_port=$(_server_info_val daemon_port)
    local proto=$(_server_info_val protocol)
    local lip=$(_server_info_val lan_ip)
    local pip=$(_server_info_val public_ip)
    local uname=$(_server_info_val username)
    local started=$(_server_info_val started_at)

    local pid=""
    [ -f "$PID_FILE" ] && pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        local uptime=$(ps -o etime= -p "$pid" 2>/dev/null | xargs)
        echo ""
echo "  [运行中] 面板 (Panel)"
        echo "  PID: $pid"
        echo "  运行时长: ${uptime:-未知}"
    else
        echo "  [未运行] 面板 (Panel)"
    fi

    local dpid=""
    [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
        local duptime=$(ps -o etime= -p "$dpid" 2>/dev/null | xargs)
        echo "  [运行中] 守护进程 (Daemon)"
        echo "  PID: $dpid"
        echo "  运行时长: ${duptime:-未知}"
    else
        echo "  [未运行] 守护进程 (Daemon)"
    fi

    echo ""
    if [ -n "$u_port" ]; then
        echo "  用户端:  ${proto:-http}://${lip:-?}:$u_port"
        [ -n "$pip" ] && echo "  公网:    ${proto:-http}://$pip:$u_port"
        echo "  管理台:  ${proto:-http}://${lip:-?}:$a_port/console.html"
        [ -n "$pip" ] && echo "  公网:    ${proto:-http}://$pip:$a_port/console.html"
        echo "  用户名:   $uname"
        [ -n "$d_port" ] && echo "  守护进程: 端口 $d_port"
    fi
    echo "  安装目录: $STW_DIR"
    echo "  数据目录: $DATA_DIR"
    echo "  Mod 目录: $MOD_DIR"
    echo ""
    tail -5 "$SERVER_LOG" 2>/dev/null | sed 's/^/  /'
}

# -- 读取/修改配置 --
_load_server_info() {
    local f="$DATA_DIR/server_info.json"
    if [ ! -f "$f" ]; then
        SERVER_INFO=""
        return
    fi
    SERVER_INFO=$($PYTHON -c "
import json
d=json.load(open('$f'))
print(json.dumps(d))
" 2>/dev/null || echo "")
}

_server_info_val() {
    local key="$1"
    [ -z "$SERVER_INFO" ] && { echo ""; return; }
    $PYTHON -c "
import json,sys
d=json.loads(sys.argv[1])
print(d.get('$key',''))
" "$SERVER_INFO" 2>/dev/null || echo ""
}

_get_default_info() {
    echo ""
    echo "  短信转网页 — 默认信息"
    echo ""
    _detect_os
    echo ""
    _load_server_info
    local u_port=$(_server_info_val user_port)
    local a_port=$(_server_info_val admin_port)
    local d_port=$(_server_info_val daemon_port)
    local uname=$(_server_info_val username)
    local proto=$(_server_info_val protocol)
    local lip=$(_server_info_val lan_ip)
    local pip=$(_server_info_val public_ip)
    local status=$(_server_info_val status)
    if [ -n "$u_port" ]; then
        echo "  状态: $status"
        echo ""
        echo "  用户端:  ${proto:-http}://${lip:-?}:$u_port"
        [ -n "$pip" ] && echo "  公网:    ${proto:-http}://$pip:$u_port"
        echo "  管理台:  ${proto:-http}://${lip:-?}:$a_port/console.html"
        [ -n "$pip" ] && echo "  公网:    ${proto:-http}://$pip:$a_port/console.html"
        echo "  用户名:   $uname"
        [ -n "$d_port" ] && echo "  守护进程: 端口 $d_port"
    else
        warn "服务未运行，无法获取端口信息"
    fi
    if [ -f "$MANAGERS" ]; then
        echo ""
        echo "  管理员用户:"
        _get_managers | while read u h l t; do
            echo "    用户名: $u  等级: $l  创建: $t"
        done
    fi
    echo ""
    echo "  数据目录: $DATA_DIR"
    echo "  Mod目录: $MOD_DIR"
    echo "  日志文件: $SERVER_LOG"
    echo ""
}

# -- 查看全部配置 --
_view_config() {
    echo ""
    echo "  当前配置"
    echo "  ---------------------"
    if [ -f "$CONFIG_FILE" ]; then
        $PYTHON -c "
import json
d=json.load(open('$CONFIG_FILE'))
for k,v in d.items():
    print(f'  {k}: {v}')
" 2>/dev/null || echo "  (空)"
    else
        echo "  (配置文件不存在)"
    fi
    echo ""
    read -p "  按回车继续..."
}

# -- 编辑配置 --
_edit_config() {
    echo ""
    echo "  编辑配置"
    echo "  ---------------------"
    read -p "  配置项名称: " key
    read -p "  配置值: " val
    [ -z "$key" ] && { fail "配置项不能为空"; return; }
    _write_json "$CONFIG_FILE" "$key" "$val"
    ok "已设置 $key = $val（重启后生效）"
}

# -- 重启模式 --
_restart_mode() {
    echo ""
    local cur=$(_read_json "$CONFIG_FILE" "config_mode")
    [ -z "$cur" ] && cur="manual"
    echo "  当前模式: $cur"
    echo "  ---------------------"
    echo "  1) 手动模式 — 配置永不覆盖，保留用户设置"
    echo "  2) 自动模式 — 每次重启根据当前系统自动生成配置"
    echo ""
    read -p "  选择 [1/2]: " ch
    if [ "$ch" = "2" ]; then
        _write_json "$CONFIG_FILE" "config_mode" "auto"
        ok "切换为自动模式 (重启后生效)"
    else
        _write_json "$CONFIG_FILE" "config_mode" "manual"
        ok "切换为手动模式 (配置保持不动)"
    fi
}

# -- 主题配置 --
_theme_config() {
    echo ""
    echo "  网页主题设置"
    echo "  ---------------------"
    local bg=$(_read_json "$CONFIG_FILE" "theme_bg")
    local font=$(_read_json "$CONFIG_FILE" "theme_font")
    local color=$(_read_json "$CONFIG_FILE" "theme_color")
    local radius=$(_read_json "$CONFIG_FILE" "theme_radius")
    local shadow=$(_read_json "$CONFIG_FILE" "theme_shadow")
    local dark=$(_read_json "$CONFIG_FILE" "theme_dark")
    local font_size=$(_read_json "$CONFIG_FILE" "theme_font_size")
    local gradient=$(_read_json "$CONFIG_FILE" "theme_gradient")
    local blur=$(_read_json "$CONFIG_FILE" "theme_blur")
    local anim=$(_read_json "$CONFIG_FILE" "theme_animation")
    local density=$(_read_json "$CONFIG_FILE" "theme_density")
    local preset=$(_read_json "$CONFIG_FILE" "theme_preset")
    echo "  当前:"
    echo "    预设:      ${preset:-无}"
    echo "    主色:      ${color:-默认}"
    echo "    背景:      ${bg:-无}"
    echo "    渐变:      ${gradient:-无}"
    echo "    字体:      ${font:-默认}"
    echo "    字号:      ${font_size:-默认}"
    echo "    圆角:      ${radius:-默认}"
    echo "    阴影:      ${shadow:-默认}"
    echo "    模糊:      ${blur:-无}"
    echo "    深色模式:  ${dark:-关}"
    echo "    动画:      ${anim:-开}"
    echo "    密度:      ${density:-标准}"
    echo ""
    echo "  1) 主色调 (hex)    2) 背景图片URL"
    echo "  3) 渐变背景CSS     4) 字体名称(自填)"
    echo "  5) 字号 (px)       6) 圆角 (px)"
    echo "  7) 阴影 (CSS值)    8) 模糊 (px)"
    echo "  9) 深色模式开/关  10) 动画开/关"
    echo " 11) 布局密度       12) 应用预设主题"
    echo " 13) 字体预设       14) 恢复全部默认"
    echo ""
    read -p "  选择 [1-14]: " ch
    case "$ch" in
        1) read -p "  主色 (hex, 如 #1890ff): " val; _write_json "$CONFIG_FILE" "theme_color" "$val"; ok "主色已设置" ;;
        2) read -p "  背景图片URL: " val; _write_json "$CONFIG_FILE" "theme_bg" "$val"; _write_json "$CONFIG_FILE" "theme_gradient" ""; ok "背景已设置" ;;
        3) read -p "  渐变CSS (如 linear-gradient(...)): " val; _write_json "$CONFIG_FILE" "theme_gradient" "$val"; _write_json "$CONFIG_FILE" "theme_bg" ""; ok "渐变已设置" ;;
        4) read -p "  字体名称 (如 PingFang SC, Noto Sans SC): " val; _write_json "$CONFIG_FILE" "theme_font" "$val"; ok "字体已设置" ;;
        5) read -p "  字号 (px, 如 16): " val; _write_json "$CONFIG_FILE" "theme_font_size" "${val}px"; ok "字号已设置" ;;
        6) read -p "  圆角 (px, 0-20): " val; _write_json "$CONFIG_FILE" "theme_radius" "$val"; ok "圆角已设置" ;;
        7) read -p "  阴影CSS (如 0 4px 12px rgba(0,0,0,0.1)): " val; _write_json "$CONFIG_FILE" "theme_shadow" "$val"; ok "阴影已设置" ;;
        8) read -p "  模糊 (px, 0-20): " val; _write_json "$CONFIG_FILE" "theme_blur" "$val"; ok "模糊已设置" ;;
        9)
            if [ "$dark" = "true" ]; then
                _write_json "$CONFIG_FILE" "theme_dark" "false"; ok "深色模式已关闭"
            else
