            esac
            ;;
        29|sysinfo)
            echo ""
            _detect_os
            echo "  内存: $(free -h 2>/dev/null | awk '/^Mem:/{print $2}')"
            echo "  磁盘: $(df -h "$STW_DIR" 2>/dev/null | awk 'NR==2{print $3 "/" $2 " (" $5 ")"}')"
            echo "  运行时间: $(uptime -p 2>/dev/null || uptime)"
            _status
            ;;
        30|firewall)
            echo ""
            info "检测已开放端口..."
            local u_port=$(_get_port "用户")
            local a_port=$(_get_port "管理")
            if command -v ufw >/dev/null 2>&1; then
                for p in $u_port $a_port; do
                    [ -n "$p" ] && { ufw allow "$p/tcp" 2>/dev/null && ok "ufw 已放行端口 $p" || warn "ufw 放行失败"; }
                done
            elif command -v firewall-cmd >/dev/null 2>&1; then
                for p in $u_port $a_port; do
                    [ -n "$p" ] && { firewall-cmd --permanent --add-port="$p/tcp" 2>/dev/null && firewall-cmd --reload 2>/dev/null && ok "firewalld 已放行端口 $p"; }
                done
            elif command -v iptables >/dev/null 2>&1; then
                for p in $u_port $a_port; do
                    [ -n "$p" ] && { iptables -A INPUT -p tcp --dport "$p" -j ACCEPT 2>/dev/null && ok "iptables 已放行端口 $p"; }
                done
            else
                warn "未检测到防火墙工具，请手动放行端口: $u_port $a_port"
            fi
            ;;
        31|mail)
            echo ""
            echo "  配置 SMTP 邮件"
            read -p "  SMTP服务器: " host
            read -p "  端口: " port
            read -p "  邮箱账号: " user
            read -s -p "  密码/授权码: " pass; echo ""
            read -p "  发件人地址: " from
            cat > "$DATA_DIR/mail_config.json" <<EOF
{
  "host": "$host",
  "port": ${port:-465},
  "user": "$user",
  "password": "$pass",
  "from_addr": "$from",
  "from_name": "短信转网页",
  "tls": true,
  "enabled": true
}
EOF
            ok "邮件配置已保存"
            ;;
        32|users)
            echo ""
            if [ ! -f "$DATA_DIR/sms.db" ]; then
                warn "数据库不存在，请先启动服务"
                return
            fi
            $PYTHON -c "
import sqlite3
try:
    db=sqlite3.connect('$DATA_DIR/sms.db')
    db.row_factory=sqlite3.Row
    rows=db.execute('SELECT id,phone,email,is_active,registered_at FROM users ORDER BY id').fetchall()
    if not rows: print('  (暂无用户)')
    for r in rows:
        print(f'  ID:{r[\"id\"]} | 手机:{r[\"phone\"]} | 邮箱:{r[\"email\"] or \"-\"} | 状态:{\"活跃\" if r[\"is_active\"] else \"禁用\"} | 注册:{r[\"registered_at\"]}')
except Exception as e:
    print(f'  读取失败: {e}')
" 2>/dev/null
            ;;
        33|reset)
            echo ""
            warn "此操作将重置所有设置（数据将被清空）"
            _yes_no "确定要继续吗?" "no" || { info "已取消"; return; }
            _stop 2>/dev/null
            rm -f "$MANAGERS" "$CONFIG_FILE" "$DATA_DIR"/sms.db 2>/dev/null
            ok "已重置所有设置"
            ;;
        34|update)
            echo ""
            info "检查更新..."
            info "当前版本: 1.0"
            echo "  请访问 https://github.com/Li-Zhangye/stw/releases 下载最新版本"
            ;;
        35|register)
            local cur=$(_read_json "$CONFIG_FILE" "registration_enabled")
            [ -z "$cur" ] && cur="true"
            if [ "$cur" = "true" ]; then
                _write_json "$CONFIG_FILE" "registration_enabled" "false"
                ok "注册功能已关闭"
            else
                _write_json "$CONFIG_FILE" "registration_enabled" "true"
                ok "注册功能已开启"
            fi
            ;;
        36|sms-limit)
            read -p "  每个用户每日短信上限 (0=无限制): " limit
            [[ "$limit" != [0-9]* ]] && { fail "请输入数字"; return; }
            _write_json "$CONFIG_FILE" "daily_sms_limit" "${limit:-0}"
            ok "每日短信限额已设置: ${limit:-无限制}"
            ;;
        37|ssl)
            echo ""
            echo "  1) 开启SSL (自签名)"
            echo "  2) 关闭SSL"
            read -p "  选择: " ch
            if [ "$ch" = "1" ]; then
                if command -v openssl >/dev/null 2>&1; then
                    _write_json "$CONFIG_FILE" "ssl_enabled" "true"
                    ok "SSL 已开启（重启后生效）"
                else
                    fail "openssl 未安装，无法开启 SSL"
                fi
            else
                _write_json "$CONFIG_FILE" "ssl_enabled" "false"
                ok "SSL 已关闭"
            fi
            ;;
        38|fix)
            echo ""
            info "修复服务..."
            _stop 2>/dev/null
            rm -f "$PID_FILE"
            for f in server/server.py server/check_env.py server/db.py server/mail.py; do
                [ -f "$STW_DIR/$f" ] && ok "存在: $f" || fail "缺失: $f"
            done
            for d in tmp/data mod/public mod/server mod/plugins; do
                mkdir -p "$STW_DIR/$d" 2>/dev/null
            done
            if [ -f "$STW_DIR/server/check_env.py" ]; then
                DATA_DIR="$DATA_DIR" $PYTHON "$STW_DIR/server/check_env.py" --quick 2>/dev/null || true
            fi
            _start
            ok "修复完成"
            ;;
        39|about)
            echo ""
            echo "  短信转网页 SMS2Web v1.0"
            echo "  将短信转发到网页，支持多用户 + Mod 扩展系统"
            echo ""
            echo "  命令: stw [选项编号]"
            echo "  示例: stw 1    重启服务"
            echo "  示例: stw 11   查看信息"
            echo ""
            ;;
        40|daemon-status)
            _daemon_status ;;
        41|daemon-start)
            _start_daemon_only ;;
        42|daemon-stop)
            _stop_daemon_only ;;
        43|clean-cache)
            echo ""
            info "缓存扫描中..."
            local has_log=0; local has_pyc=0; local has_sess=0
            [ -f "$SERVER_LOG" ] || [ -f "$DAEMON_LOG" ] && has_log=1
            find "$STW_DIR" -name "*.pyc" -o -type d -name "__pycache__" 2>/dev/null | head -1 >/dev/null && has_pyc=1
            find "$DATA_DIR" -name "session_*" 2>/dev/null | head -1 >/dev/null && has_sess=1
            local has_apt=0; local has_dnf=0; local has_yum=0; local has_pac=0; local has_journal=0
            command -v apt-get >/dev/null && has_apt=1
            command -v dnf >/dev/null && has_dnf=1
            command -v yum >/dev/null && has_yum=1
            command -v pacman >/dev/null && has_pac=1
            command -v journalctl >/dev/null && has_journal=1
            echo ""
            echo "  可清理项:"
            echo "    面板缓存: $([ "$has_log$has_pyc$has_sess" != "000" ] && echo '检测到' || echo '无')"
            [ "$has_log" = "1" ] && echo "      - 运行日志文件"
            [ "$has_pyc" = "1" ] && echo "      - Python 编译缓存（.pyc / __pycache__）"
            [ "$has_sess" = "1" ] && echo "      - 登录会话文件"
            echo "    系统缓存: $([ "$has_apt$has_dnf$has_yum$has_pac$has_journal" != "00000" ] && echo '检测到' || echo '无')"
            [ "$has_apt" = "1" ] && echo "      - APT 包缓存"
            [ "$has_dnf" = "1" ] && echo "      - DNF 包缓存"
            [ "$has_yum" = "1" ] && echo "      - YUM 包缓存"
            [ "$has_pac" = "1" ] && echo "      - Pacman 包缓存"
            [ "$has_journal" = "1" ] && echo "      - Systemd 日志"
            echo ""
            echo "  请选择清理项:"
            echo "    (1) 仅面板缓存"
            echo "    (2) 仅系统缓存"
            echo "    (3) 全部清理"
            echo "    (0) 取消"
            read -p "  请输入 [0-3]: " clean_choice
            case "$clean_choice" in
                1) _clean_panel_cache ;;
                2) _clean_system_cache ;;
                3) _clean_panel_cache; _clean_system_cache ;;
                *) info "已取消" ;;
            esac
            ;;
        menu|"")
            while true; do
                _show_menu
                read -r input
                [ -z "$input" ] && continue
                echo ""
                if [ "$input" = "0" ] || [ "$input" = "q" ] || [ "$input" = "exit" ]; then
                    echo "  再见"; break
                fi
                _main "$input"
                echo ""
                read -p "  按回车继续..."
            done
            ;;
        *)
            echo ""
            echo "  stw — 短信转网页命令行工具箱"
            echo "  用法: stw [选项编号]    直接执行操作"
            echo "        stw              进入交互菜单"
            echo ""
            echo "  选项:"
            echo "    1) 重启服务       2) 停止服务       3) 启动服务"
            echo "    4) 查看状态       5) 用户端口       6) 管理端口"
            echo "    7) 用户名         8) 密码          9) 重置端口"
            echo "   10) 管理员管理    11) 默认信息      12) 查看配置"
            echo "   13) 编辑配置      14) 重启模式      15) 主题设置"
            echo "   16) 清除登录限制  17) 安全入口      18) IP白名单"
            echo "   19) 取消白名单    20) 绑定域名      21) 解除域名"
            echo "   22) 运行日志      23) 错误日志      24) 清除日志"
            echo "   25) 备份数据      26) 恢复数据      27) 磁盘清理"
            echo "   28) 语言          29) 系统信息      30) 防火墙"
            echo "   31) 邮件配置      32) 用户列表      33) 重置设置"
            echo "   34) 更新          35) 注册开关      36) 短信限额"
            echo "   37) SSL           38) 修复          39) 关于"
            echo "   40) 守护状态      41) 启动守护      42) 停止守护"
            echo "   43) 清理缓存      0) 退出"
            ;;
    esac
}

# -- 入口 --
_main "$@"
