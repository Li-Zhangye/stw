#!/usr/bin/env bash
# stw - 短信转网页 服务管理工具
# 用法: stw <command>
# 命令: start, stop, restart, status

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")" && pwd)"
STW_DIR="${STW_DIR:-$SCRIPT_DIR}"
SERVER_PY="$STW_DIR/server/server.py"
DATA_DIR="${DATA_DIR:-$STW_DIR/tmp/data}"
MOD_DIR="${MOD_DIR:-$STW_DIR/mod}"
PID_FILE="$STW_DIR/tmp/server.pid"
DAEMON_PID_FILE="$DATA_DIR/daemon.pid"
LOG_DIR="$STW_DIR/tmp"
SERVER_LOG="$LOG_DIR/server.log"
DAEMON_LOG="$LOG_DIR/daemon.log"

[ -t 1 ] && { BOLD='\033[1m'; RED='\033[91m'; GREEN='\033[92m'; YELLOW='\033[93m'; CYAN='\033[96m'; RESET='\033[0m'; } || { BOLD=''; RED=''; GREEN=''; YELLOW=''; CYAN=''; RESET=''; }
ok()   { echo "  [OK] $1"; }
fail() { printf "  ${RED}[FAIL]${RESET} %s\n" "$1"; }
warn() { echo "  [!] $1"; }
info() { echo "  [i] $1"; }

PYTHON=$(command -v python3 || command -v python || true)
[ -z "$PYTHON" ] && { fail "Python not found"; exit 1; }

_load_server_info() {
    local f="$DATA_DIR/server_info.json"
    [ ! -f "$f" ] && { SERVER_INFO=""; return; }
    SERVER_INFO=$($PYTHON -c "import json; print(json.dumps(json.load(open('$f'))))" 2>/dev/null || echo "")
}

_server_info_val() {
    local key="$1"
    [ -z "$SERVER_INFO" ] && { echo ""; return; }
    $PYTHON -c "import json,sys; d=json.loads(sys.argv[1]); print(d.get('$key',''))" "$SERVER_INFO" 2>/dev/null || echo ""
}

_start() {
    [ -f "$PID_FILE" ] && { local pid=$(cat "$PID_FILE" 2>/dev/null); kill -0 "$pid" 2>/dev/null && { warn "Panel already running (PID $pid)"; return; }; }
    mkdir -p "$DATA_DIR" "$LOG_DIR"
    cd "$STW_DIR"
    DATA_DIR="$DATA_DIR" MOD_DIR="$MOD_DIR" nohup $PYTHON "$SERVER_PY" > "$SERVER_LOG" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    sleep 3
    if kill -0 "$pid" 2>/dev/null; then
        ok "Panel started (PID $pid)"
        local dpid=""; [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
        [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null && ok "Daemon running (PID $dpid)" || warn "Daemon may not have started, check: $DAEMON_LOG"
    else
        fail "Panel failed to start, check: $SERVER_LOG"
    fi
}

_stop() {
    local pid
    if [ -f "$PID_FILE" ]; then
        pid=$(cat "$PID_FILE" 2>/dev/null)
        kill "$pid" 2>/dev/null && ok "Panel stopped (PID $pid)" || warn "Panel PID $pid not found"
        rm -f "$PID_FILE"
    else
        pid=$(pgrep -f "server.py" 2>/dev/null | head -1)
        [ -n "$pid" ] && { kill "$pid" 2>/dev/null && ok "Panel stopped"; } || warn "No running panel found"
    fi
    local dpid=""; [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    [ -n "$dpid" ] && kill "$dpid" 2>/dev/null && ok "Daemon stopped" || true
    rm -f "$DAEMON_PID_FILE"
    dpid=$(pgrep -f "daemon.py" 2>/dev/null | head -1)
    [ -n "$dpid" ] && kill "$dpid" 2>/dev/null && ok "Daemon force stopped" || true
}

_status() {
    _load_server_info
    local u_port=$(_server_info_val user_port) a_port=$(_server_info_val admin_port)
    local d_port=$(_server_info_val daemon_port) proto=$(_server_info_val protocol)
    local lip=$(_server_info_val lan_ip) pip=$(_server_info_val public_ip)
    local uname=$(_server_info_val username)
    echo ""
    local pid=""; [ -f "$PID_FILE" ] && pid=$(cat "$PID_FILE" 2>/dev/null)
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        echo "  ${GREEN}[Running]${RESET} Panel (PID $pid) $(ps -o etime= -p "$pid" 2>/dev/null | xargs)"
    else
        echo "  ${RED}[Stopped]${RESET} Panel"
    fi
    local dpid=""; [ -f "$DAEMON_PID_FILE" ] && dpid=$(cat "$DAEMON_PID_FILE" 2>/dev/null)
    if [ -n "$dpid" ] && kill -0 "$dpid" 2>/dev/null; then
        echo "  ${GREEN}[Running]${RESET} Daemon (PID $dpid) $(ps -o etime= -p "$dpid" 2>/dev/null | xargs)"
    else
        echo "  ${RED}[Stopped]${RESET} Daemon"
    fi
    if [ -n "$u_port" ]; then
        echo ""
        echo "  User:  ${proto:-http}://${lip:-?}:$u_port"
        [ -n "$pip" ] && echo "  Pub:   ${proto:-http}://$pip:$u_port"
        echo "  Admin: ${proto:-http}://${lip:-?}:$a_port/console.html"
        [ -n "$pip" ] && echo "  Pub:   ${proto:-http}://$pip:$a_port/console.html"
        echo "  Login: $uname"
        [ -n "$d_port" ] && echo "  Daemon port: $d_port"
    fi
    echo "  Dir: $STW_DIR"
    echo ""
    tail -3 "$SERVER_LOG" 2>/dev/null | sed 's/^/  /'
}

case "${1:-}" in
    start)   _start ;;
    stop)    _stop ;;
    restart) _stop; sleep 1; _start ;;
    status)  _status ;;
    help|--help|-h)
        echo "Usage: stw <command>"
        echo "Commands:"
        echo "  start    Start panel server"
        echo "  stop     Stop panel server"
        echo "  restart  Restart panel server"
        echo "  status   Show server status"
        ;;
    "")
        _status
        echo ""
        echo "  Run 'stw help' for commands"
        ;;
    *)
        fail "Unknown command: $1"
        echo "Usage: stw start|stop|restart|status"
        exit 1
        ;;
esac
