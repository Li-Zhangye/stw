            ;;
        12|view-config)
            _view_config ;;
        13|edit-config)
            _edit_config ;;
        14|restart-mode)
            _restart_mode ;;
        15|theme)
            _theme_config ;;
        16|clear-login-limit)
            rm -f "$DATA_DIR/login_limits" "$DATA_DIR"/*.login 2>/dev/null
            ok "登录限制已清除"
            ;;
        17|security-path|set-security-path|unset-security-path|view-security-path)
            echo ""
            local cur_path
            cur_path=$($PYTHON -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
print(cfg.get('security_path', '') or '')
" 2>/dev/null || echo "")
            if [ -n "$cur_path" ]; then
                echo "  当前安全入口: $cur_path（已开启）"
                local a_port=$(_get_port "管理")
                local proto; proto=$(_ssl_is_active)
                local lan_ip
                lan_ip=$(hostname -I 2>/dev/null | awk '{print $1}' | grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | head -1 || echo "")
                local pub_ip
                pub_ip=$(curl -fsL --connect-timeout 3 ifconfig.me 2>/dev/null || wget -qO- --timeout=3 ifconfig.me 2>/dev/null || echo "")
