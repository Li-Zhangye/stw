            ;;
        14)
            for k in theme_bg theme_font theme_color theme_radius theme_shadow theme_dark theme_font_size theme_gradient theme_blur theme_animation theme_density theme_preset; do
                _write_json "$CONFIG_FILE" "$k" ""
            done
            ok "已恢复全部默认"
            ;;
        *) fail "无效选择" ;;
    esac
}

