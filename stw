# -- 添加管理员 --
_add_admin() {
    echo ""
    echo "  添加超级管理员"
    echo "  ---------------------"
    read -p "  用户名: " uname
    [ -z "$uname" ] && { fail "用户名不能为空"; return; }
    read -s -p "  密码 (回车随机): " pwd1; echo ""
    [ -z "$pwd1" ] && pwd1=$(_random_password) && echo "  随机密码: $pwd1"
    [ ${#pwd1} -lt 8 ] && { fail "密码至少8位"; return; }
    local tmpf=$(mktemp /tmp/stw_add.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_add.$$"
    printf '%s\n' "$uname" > "$tmpf"
    printf '%s' "$pwd1" >> "$tmpf"
    $PYTHON -c "
import hashlib, secrets, json, os, time
lines = open('$tmpf', 'r').read().split('\n')
uname = lines[0]
pwd = lines[1]
salt = secrets.token_hex(16)
h = hashlib.pbkdf2_hmac('sha256', pwd.encode(), salt.encode(), 600000).hex()
managers = []
if os.path.exists('$MANAGERS'):
    managers = json.load(open('$MANAGERS'))
managers.append({
    'username': uname,
    'password_hash': salt + ':' + h,
    'level': 3,
    'created_at': time.strftime('%Y-%m-%d %H:%M:%S'),
    'created_by': 'stw'
})
os.makedirs('$(dirname "$MANAGERS")', exist_ok=True)
json.dump(managers, open('$MANAGERS', 'w'), ensure_ascii=False, indent=2)
os.chmod('$MANAGERS', 0o600)
print('ok')
" 2>/dev/null | grep -q ok && ok "超级管理员 $uname 已添加" || fail "添加失败"
    rm -f "$tmpf"
}

# -- 删除管理员 --
_del_admin() {
    echo ""
    echo "  删除管理员"
    echo "  ---------------------"
    $PYTHON -c "
import json
d=json.load(open('$MANAGERS'))
for i,m in enumerate(d):
    print(f'  [{i}] {m[\"username\"]} (level {m[\"level\"]})')
" 2>/dev/null || { warn "无管理员"; return; }
    echo ""
    read -p "  输入要删除的编号: " idx
    local tmpf=$(mktemp /tmp/stw_del.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_del.$$"
    printf '%s' "$idx" > "$tmpf"
    $PYTHON -c "
import json
idx = int(open('$tmpf','r').read().strip())
d=json.load(open('$MANAGERS'))
if idx < len(d):
    removed = d.pop(idx)
    json.dump(d, open('$MANAGERS','w'), indent=2, ensure_ascii=False)
    print(f'removed {removed[\"username\"]}')
" 2>/dev/null | grep -q removed && ok "已删除" || fail "无效编号"
    rm -f "$tmpf"
}

