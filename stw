# -- 主逻辑 --
_main() {
    local cmd="${1:-}"
    case "$cmd" in
        1|restart)
            _stop; sleep 1; _start ;;
        2|stop)
            _stop ;;
        3|start)
            _start ;;
        4|status)
            _status ;;
        5|user-port)
            echo ""
            echo "  修改用户端口"
            echo "  -----------------"
            echo "  1) 随机生成"
            echo "  2) 自定义端口"
            read -p "  请选择 [1/2]: " ch
            if [ "$ch" = "2" ]; then
                read -p "  输入端口 (1-65535): " port
                [[ "$port" != [0-9]* || "$port" -lt 1 || "$port" -gt 65535 ]] && { fail "端口必须是 1-65535 的数字"; return; }
            else
                port=$(( RANDOM % 50000 + 1024 ))
                echo "  随机端口: $port"
            fi
            _write_json "$CONFIG_FILE" "force_user_port" "$port"
            ok "已配置用户端口: $port（重启后生效）"
            ;;
        6|admin-port)
            echo ""
            echo "  修改管理端口"
            read -p "  1) 随机  2) 自定义: " ch
            if [ "$ch" = "2" ]; then
                read -p "  输入端口 (1-65535): " port
                [[ "$port" != [0-9]* || "$port" -lt 1 || "$port" -gt 65535 ]] && { fail "端口必须是 1-65535 的数字"; return; }
            else
                port=$(( RANDOM % 50000 + 1024 ))
                echo "  随机端口: $port"
            fi
            _write_json "$CONFIG_FILE" "force_admin_port" "$port"
            ok "已配置管理端口: $port（重启后生效）"
            ;;
        7|username)
            echo ""
            read -p "  输入新管理员用户名: " uname
            [ -z "$uname" ] && { fail "用户名不能为空"; return; }
            local tmpf=$(mktemp /tmp/stw_usr.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_usr.$$"
            printf '%s' "$uname" > "$tmpf"
            $PYTHON -c "
import json
uname = open('$tmpf', 'r').read()
with open('$MANAGERS') as f:
    m = json.load(f)
if not m:
    print('ERROR: 无管理员可修改')
    exit(1)
m[0]['username'] = uname
with open('$MANAGERS', 'w') as f:
    json.dump(m, f, ensure_ascii=False, indent=2)
print('OK')
" 2>/dev/null && ok "管理员用户名已修改（立即生效）" || fail "修改失败，请检查 $MANAGERS"
            rm -f "$tmpf"
            ;;
        8|password)
            echo ""
            read -s -p "  输入新管理员密码: " pwd1; echo ""
            read -s -p "  再次输入确认: " pwd2; echo ""
            [ "$pwd1" != "$pwd2" ] && { fail "两次密码不一致"; return; }
            [ ${#pwd1} -lt 8 ] && { fail "密码至少8位"; return; }
            local tmpf=$(mktemp /tmp/stw_pass.XXXXXX 2>/dev/null) || tmpf="/tmp/stw_pass.$$"
            printf '%s' "$pwd1" > "$tmpf"
            $PYTHON -c "
import hashlib, secrets, json, os
pwd = open('$tmpf', 'r').read()
salt = secrets.token_hex(16)
h = hashlib.pbkdf2_hmac('sha256', pwd.encode(), salt.encode(), 600000).hex()
path = '$MANAGERS'
with open(path) as f:
    m = json.load(f)
if not m:
