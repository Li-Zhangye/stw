m[0]['password_hash'] = salt + ':' + h
with open(path, 'w') as f:
    json.dump(m, f, ensure_ascii=False, indent=2)
os.chmod(path, 0o600)
print('OK')
" 2>/dev/null && ok "管理员密码已修改（立即生效）" || fail "修改失败，请检查 $MANAGERS"
            rm -f "$tmpf"
            ;;
        9|reset-ports)
            _reset_ports ;;
        10|admin-users)
            echo ""
            echo "  管理员管理"
            echo "  -----------------"
            echo "  1) 添加超级管理员"
            echo "  2) 删除管理员"
            read -p "  选择: " ch
            case "$ch" in 1) _add_admin ;; 2) _del_admin ;; *) fail "无效" ;; esac
            ;;
        11|info)
